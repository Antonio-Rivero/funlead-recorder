# FunLead Recorder — example environment (NO real values here).
# Phase 1 (desktop app) needs NONE of these — it is 100% local.
# The following are only for Phase 2 (optional self-hosted web server on Vercel):

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=
# Database (Postgres / Neon)
DATABASE_URL=
# Optional: direct (non-pooled) connection for Prisma migrations (Neon).
DIRECT_DATABASE_URL=
# Single-user auth for the web dashboard
RECORDING_OWNER_PASSWORD=
# Cookie signing secret for the owner session / share-link gates
RECORDING_GATE_COOKIE_SECRET=
# Optional: max upload size in MB for recordings (default 1024).
RECORDING_MAX_UPLOAD_MB=
